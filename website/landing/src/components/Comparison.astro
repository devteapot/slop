---
---
<section class="comparison">
  <div class="container">
    <span class="label">Why SLOP</span>
    <h2>How it differs</h2>

    <div class="glass table-wrapper">
      <table>
        <thead>
          <tr>
            <th></th>
            <th>MCP / Tool calls</th>
            <th>Accessibility APIs</th>
            <th class="highlight">SLOP</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td class="row-label">Purpose</td>
            <td>AI acts</td>
            <td>Screen readers read UI</td>
            <td class="highlight">AI perceives + acts</td>
          </tr>
          <tr>
            <td class="row-label">Data model</td>
            <td>Flat list of functions</td>
            <td>UI element tree</td>
            <td class="highlight">Semantic state tree</td>
          </tr>
          <tr>
            <td class="row-label">Direction</td>
            <td>Pull (AI calls tools)</td>
            <td>Pull (reader queries)</td>
            <td class="highlight">Push-first (app publishes)</td>
          </tr>
          <tr>
            <td class="row-label">Actions</td>
            <td>Global tool registry</td>
            <td>Limited (click, type)</td>
            <td class="highlight">Contextual affordances</td>
          </tr>
          <tr>
            <td class="row-label">Designed for</td>
            <td>LLM function calling</td>
            <td>Sequential navigation</td>
            <td class="highlight">AI state comprehension</td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</section>

<style>
  .comparison h2 {
    font-size: 2.25rem;
    margin-top: var(--space-4);
    margin-bottom: var(--space-8);
  }
  .table-wrapper {
    padding: var(--space-5);
    overflow-x: auto;
  }
  table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9375rem;
  }
  th, td {
    text-align: left;
    padding: var(--space-3) var(--space-4);
  }
  thead th {
    color: var(--text-tertiary);
    font-family: var(--font-machine);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    padding-bottom: var(--space-4);
  }
  tbody tr {
    background: transparent;
    transition: background 0.15s;
  }
  tbody tr:hover {
    background: var(--surface-container-low);
  }
  tbody td {
    color: var(--text-secondary);
  }
  .row-label {
    color: var(--text-primary);
    font-weight: 500;
    white-space: nowrap;
  }
  .highlight {
    color: var(--primary) !important;
    font-weight: 500;
  }
  thead .highlight {
    color: var(--primary) !important;
  }
</style>
