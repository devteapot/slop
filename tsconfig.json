{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "strict": true,
    "declaration": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@slop/types": ["./packages/types/src"],
      "@slop/provider": ["./packages/provider/src"],
      "@slop/consumer": ["./packages/consumer/src"]
    }
  }
}
