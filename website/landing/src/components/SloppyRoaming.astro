<style>
  .sloppy-roaming {
    position: fixed;
    right: -120px;
    top: 50%;
    transform: translateY(-50%);
    width: 90px;
    z-index: 90;
    cursor: pointer;
    filter: drop-shadow(0 0 20px rgba(59, 130, 246, 0.3));
    transition: right 0.6s cubic-bezier(0.32, 0.72, 0, 1);
    pointer-events: none;
  }

  .sloppy-roaming.visible {
    right: -25px;
    transform: translateY(-50%) rotate(-10deg);
    pointer-events: auto;
  }

  .sloppy-roaming.dead {
    right: -10px;
    top: calc(100vh - 30px);
    transform: translateY(0) rotate(180deg);
    pointer-events: auto;
    cursor: pointer;
    opacity: 0.5;
    transition: top 0.8s cubic-bezier(0.4, 0, 1, 1),
                right 0.8s ease-out,
                transform 0.8s ease-in,
                opacity 0.6s ease 0.3s;
  }

  .sloppy-roaming.dismissed {
    right: -120px;
    opacity: 0;
    transition: right 0.5s ease-in, opacity 0.5s ease-in;
    pointer-events: none;
  }

  .sloppy-roaming .sloppy-svg {
    width: 100%;
    height: auto;
    display: block;
  }

  .sloppy-roaming .sloppy-iris {
    transition: fill 0.3s ease;
  }

  .sloppy-roaming.angry .sloppy-iris {
    fill: #f87171;
  }

  .sloppy-roaming .sloppy-pupil-group {
    will-change: transform;
    transition: transform 0.08s linear;
  }

  .sloppy-roaming.cross-eyed .sloppy-iris {
    fill: #c4d94f;
  }

  .sloppy-roaming.cross-eyed {
    animation: sloppy-roam-shake 0.3s ease-in-out infinite;
  }

  .sloppy-roaming.happy {
    animation: sloppy-roam-jump 0.4s ease-in-out;
  }

  @keyframes sloppy-roam-shake {
    0%, 100% { transform: translateY(-50%) rotate(-10deg); }
    25% { transform: translateY(-50%) rotate(-11deg); }
    75% { transform: translateY(-50%) rotate(-9deg); }
  }

  @keyframes sloppy-roam-jump {
    0% { transform: translateY(-50%) rotate(-10deg); }
    20% { transform: translateY(calc(-50% - 10px)) rotate(-10deg); }
    40% { transform: translateY(-50%) rotate(-10deg); }
    60% { transform: translateY(calc(-50% - 8px)) rotate(-10deg); }
    80% { transform: translateY(-50%) rotate(-10deg); }
    100% { transform: translateY(-50%) rotate(-10deg); }
  }

  @media (max-width: 768px) {
    .sloppy-roaming {
      display: none;
    }
  }
</style>
