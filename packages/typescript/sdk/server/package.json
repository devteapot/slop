{
  "name": "@slop-ai/server",
  "version": "0.1.0",
  "description": "SLOP server/native provider — createSlopServer() + WebSocket, Unix socket, stdio transports",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./node": {
      "import": "./dist/transports/node.js",
      "types": "./dist/transports/node.d.ts"
    },
    "./bun": {
      "import": "./dist/transports/bun.js",
      "types": "./dist/transports/bun.d.ts"
    },
    "./unix": {
      "import": "./dist/transports/unix.js",
      "types": "./dist/transports/unix.d.ts"
    },
    "./stdio": {
      "import": "./dist/transports/stdio.js",
      "types": "./dist/transports/stdio.d.ts"
    },
    "./nitro": {
      "import": "./dist/adapters/nitro.js",
      "types": "./dist/adapters/nitro.d.ts"
    },
    "./vite": {
      "import": "./dist/adapters/vite.js",
      "types": "./dist/adapters/vite.d.ts"
    }
  },
  "files": ["src", "dist"],
  "sideEffects": false,
  "license": "MIT",
  "homepage": "https://docs.slopai.dev/api/server",
  "bugs": "https://github.com/devteapot/slop/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/devteapot/slop",
    "directory": "packages/typescript/sdk/server"
  },
  "scripts": {
    "build": "bun build src/index.ts src/transports/node.ts src/transports/bun.ts src/transports/unix.ts src/transports/stdio.ts src/adapters/nitro.ts src/adapters/vite.ts --outdir dist --format esm --splitting --target node --external '@slop-ai/core' --external ws && bunx tsc --emitDeclarationOnly --outDir dist",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@slop-ai/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.0",
    "ws": "^8.18.0"
  }
}
